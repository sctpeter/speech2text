# 请在此处填入你的 DeepSeek API Key (从 https://platform.deepseek.com/ 获取)
# 然后将此文件重命名或复制为 .env
DEEPSEEK_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# [可选] 项目的基础物理目录路径 (在 WSL 或 Linux 下的绝对路径)，建议 clone 后依自己本机路径修改
# 若不填或注释掉此行，各个脚本也能自动识别并使用当前的运行目录 ($PWD)
BASE_DIR="/home/user/speech2text"

# [必填] Conda 安装根目录，不同用户/系统路径不同，请根据实际情况填写
# 常见路径示例：
#   Linux/WSL 普通用户: /home/<username>/miniconda3
#   Linux root 用户:    /root/miniconda
#   macOS (Homebrew):   /opt/homebrew/anaconda3
CONDA_BASE="/root/miniconda"

# [可选] Faster-Whisper 语音识别过程的 CPU 线程数限制，可以根据你电脑的核心数进行调整
# 默认如果不填则为 7。如果转录时电脑完全卡死，可以适当调低此值。
CPU_THREADS=7
